# Copy to .env and adjust as needed: cp env.example .env

STACK_VERSION=9.4.1

ELASTIC_PASSWORD=changeme
ELASTIC_USER=elastic
ELASTIC_ENDPOINT=http://elasticsearch:9200
KIBANA_PASSWORD=changeme
# Must be at least 32 characters (Kibana encrypted saved objects).
KIBANA_ENCRYPTION_KEY=changeme-changeme-changeme-changeme

ES_JAVA_OPTS=-Xms1g -Xmx1g

ES_PORT=9200
KIBANA_PORT=5601

# Use your host's LAN IP so Kibana/Observability UIs work from other devices.
# Example: KIBANA_PUBLIC_URL=http://192.168.1.42:5601
KIBANA_PUBLIC_URL=http://localhost:5601
